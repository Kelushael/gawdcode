#!/usr/bin/env python3
"""
Gawdcode CLI Agent - Connects to local GPU models
Usage: gawdcode (chat) or gawdcode terminal (web terminal)
"""

import os
import sys
import json
import subprocess
from pathlib import Path

CONFIG = Path.home() / ".gawdcode" / "config.json"

def get_gpu_info():
    """Get GPU node configuration"""
    if CONFIG.exists():
        cfg = json.loads(CONFIG.read_text())
        return cfg.get("gpus", [{}])[0].get("gpu_ip", "localhost")
    return "localhost"

def is_gpu_available():
    """Check if GPU is reachable"""
    gpu_ip = get_gpu_info()
    result = subprocess.run(
        ["curl", "-s", "-o", "/dev/null", "-w", "%{http_code}", 
         f"http://{gpu_ip}:11434/api/tags"],
        capture_output=True, text=True
    )
    return result.stdout == "200"

def chat_with_gpu():
    """Chat with local GPU model"""
    gpu_ip = get_gpu_info()
    print("=== Gawdcode Agent ===")
    print(f"GPU: {gpu_ip} (gemma4/qwen2.5-coder)")
    print("19 tools available. Type 'exit' to quit.\n")
    
    while True:
        try:
            prompt = input("gawdcode> ").strip()
            if not prompt or prompt.lower() == "exit":
                break
            
            # Send to GPU via litellm proxy
            result = subprocess.run([
                "curl", "-s", "-X", "POST",
                "-H", "Content-Type: application/json",
                "-d", json.dumps({
                    "model": "gemma4",
                    "messages": [{"role": "user", "content": prompt}],
                    "stream": False
                }),
                f"http://{gpu_ip}:4100/v1/chat/completions"
            ], capture_output=True, text=True)
            
            data = json.loads(result.stdout) if result.stdout else {}
            print(data.get("choices", [{}])[0].get("message", {}).get("content", "No response"))
            
        except KeyboardInterrupt:
            print("\n")
            break
        except Exception as e:
            print(f"Error: {e}")

def start_web_terminal():
    """Start web terminal on markyninox.com/gawdcode"""
    import webbrowser
    
    gpu_ip = get_gpu_info()
    print(f"Opening https://markyninox.com/gawdcode")
    print(f"Connected to GPU: {gpu_ip}")
    webbrowser.open("https://markyninox.com/gawdcode")

def main():
    if len(sys.argv) > 1 and sys.argv[1] == "terminal":
        start_web_terminal()
    else:
        if is_gpu_available():
            chat_with_gpu()
        else:
            print("GPU not reachable. Run 'gawdcode-setup' first.")

if __name__ == "__main__":
    main()